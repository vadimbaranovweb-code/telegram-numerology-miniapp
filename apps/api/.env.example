APP_NAME=Telegram Numerology API
APP_VERSION=0.1.0
API_PREFIX=/api/v1

# CORS: JSON array of allowed origins. Add your Vercel frontend URL here.
# Example: CORS_ORIGINS=["https://your-miniapp.vercel.app","https://your-miniapp-git-main.vercel.app"]
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

APP_STATE_STORE_MODE=sqlite
# In production on Railway/Render use a persistent volume path, e.g. /data/app-state.sqlite3
APP_STATE_STORE_PATH=/tmp/telegram-numerology-miniapp-app-state.sqlite3
APP_STATE_STORE_SQLITE_WRITE_LEGACY=true
APP_STATE_STORE_SQLITE_AUTO_MIGRATE=true

# Set to telegram_stars in production
PREMIUM_PAYMENT_PROVIDER=simulated
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
# Telegram Stars does NOT require a provider token — leave unset.
# Set to true in production so the API calls createInvoiceLink and returns a URL to the miniapp.
TELEGRAM_STARS_EXPORT_INVOICE_LINKS=false
